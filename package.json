{
  "name": "cosense2docs",
  "version": "1.0.0",
  "description": "Convert Cosense (Scrapbox) notation to formatted HTML preview and .docx",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "preview": "react-router build && vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-router/serve": "^8.2.0",
    "docx": "^9.5.0",
    "isbot": "^5",
    "react": "^19.2.0",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jszip": "^3.10.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
